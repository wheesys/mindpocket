# =========================
# MindPocket 环境变量配置
# =========================

# -------------------------
# 1. 数据库配置（必填）
# -------------------------
# PostgreSQL 数据库连接 URL
# Docker 示例: postgresql://mindpocket:password@postgres:5432/mindpocket
# 本地示例: postgresql://user:password@localhost:5432/mindpocket
# 外部数据库: postgresql://user:password@host:port/database
DATABASE_URL=

# -------------------------
# 2. 应用配置（必填）
# -------------------------
# 应用公共访问地址
# 生产示例: https://your-domain.com
# 本地示例: http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=

# -------------------------
# 3. 认证配置（必填）
# -------------------------
# 认证密钥，建议使用随机长字符串（>=32 位）
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET=

# -------------------------
# 4. 存储配置
# -------------------------
# 存储类型: local | s3 | minio
# - local: 本地文件系统存储（默认）
# - s3: AWS S3 或兼容服务
# - minio: 自建 MinIO 对象存储
STORAGE_TYPE=local

# === 本地存储配置 ===
# 本地存储路径（容器内路径或本地路径）
STORAGE_LOCAL_PATH=/data/uploads
# 公共访问 URL 前缀（可选，默认使用 NEXT_PUBLIC_APP_URL）
STORAGE_PUBLIC_URL=

# === S3/MinIO 配置 ===
# S3 兼容服务的终端地址（MinIO 必填）
# S3_ENDPOINT=http://minio:9000
# S3_ENDPOINT=https://s3.amazonaws.com
S3_ENDPOINT=

# AWS 区域
S3_REGION=us-east-1

# 存储桶名称
S3_BUCKET=mindpocket

# 访问凭证
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# 公共访问 URL（可选，用于 MinIO 自定义域名）
S3_PUBLIC_URL=

# -------------------------
# 5. 缓存/队列（可选）
# -------------------------
# Redis 连接 URL（用于缓存和 AI 功能）
# REDIS_URL=redis://:password@localhost:6379
REDIS_URL=

# Upstash Redis 配置（如使用 Upstash）
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=

# -------------------------
# 6. AI 配置（必填）
# -------------------------
# OpenAI API Key
OPENAI_API_KEY=

# OpenAI API Base URL（可选，用于兼容服务）
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=

# -------------------------
# 7. 其他配置
# -------------------------
# 时区设置
TZ=Asia/Shanghai

# Chromium 可执行文件路径（自动检测，通常无需配置）
# CHROMIUM_EXECUTABLE_PATH=
