# MindPocket Docker 环境变量配置
# 复制此文件为 .env 并修改配置

# ===========================
# 必填配置
# ===========================

# 数据库连接（必填）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 示例: postgresql://mindpocket:password@localhost:5432/mindpocket
DATABASE_URL=postgresql://mindpocket:your_password@your_db_host:5432/mindpocket

# 数据库连接参数（用于健康检查）
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=mindpocket

# 认证密钥（必填，请修改为随机字符串）
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET=change-this-to-a-random-secret-key-min-32-chars

# OpenAI API Key（必填）
OPENAI_API_KEY=your-openai-api-key-here

# ===========================
# 可选配置
# ===========================

# 应用访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 应用端口
APP_PORT=3000

# 存储类型: local | s3 | minio
STORAGE_TYPE=local

# 本地存储路径（容器内路径，一般不需要修改）
# STORAGE_LOCAL_PATH=/data/uploads

# S3/MinIO 配置（使用 S3/MinIO 时需要）
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=mindpocket
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=

# Redis 配置（可选）
# REDIS_URL=redis://:password@localhost:6379

# OpenAI API Base URL（可选，用于兼容服务）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 时区
TZ=Asia/Shanghai
